[Unit]
Description=Motion Detection Bundle service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/motion-detection
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/local/bin/motion-detection --debug
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
