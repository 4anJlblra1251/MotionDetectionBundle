[Unit]
Description=Motion Detection Bundle service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/motion-detection
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/motion-detection/.venv/bin/python /opt/motion-detection/app.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
